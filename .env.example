PORT=5000
NODE_ENV=production

# Comma-separated list is supported for preview + production domains.
CLIENT_URL=https://syed-furqan-portfolio.vercel.app

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio

# Optional email notifications. Contact form still stores messages if SMTP is not configured.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM="Portfolio Contact <no-reply@example.com>"
MAIL_TO=syedfurqan1887@gmail.com
